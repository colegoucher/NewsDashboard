# --- Database (Supabase: use the transaction-pooler URL, port 6543) ---
DATABASE_URL=postgresql://user:password@host:6543/postgres

# --- App auth: the one shared password for the dashboard ---
APP_PASSWORD=

# --- Gemini (free tier key from https://aistudio.google.com) ---
GEMINI_API_KEY=
# Optional overrides (defaults target flash-lite: 15 RPM / 1,000 req/day free):
# GEMINI_MODEL=gemini-2.5-flash-lite
# GEMINI_MAX_RPM=10
# GEMINI_DAILY_BUDGET=300

# --- Reddit (free "script" app from https://www.reddit.com/prefs/apps) ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# REDDIT_USER_AGENT=web:news-dashboard:v1.0 (by /u/yourusername)

# --- Refresh button -> GitHub workflow dispatch (Vercel only) ---
# Fine-grained token with Actions read/write on this repo.
GITHUB_REPO=owner/repo
GITHUB_TOKEN=
